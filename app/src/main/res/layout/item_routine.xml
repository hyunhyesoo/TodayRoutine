<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/gray_light"
    app:cardBackgroundColor="@color/card_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp">

        <!-- Inner Box -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/innerBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/gray_light"
            android:padding="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <CheckBox
                android:id="@+id/cbCompleted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:buttonTint="@color/checkbox_checked" />

            <TextView
                android:id="@+id/tvRoutineName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                app:layout_constraintStart_toEndOf="@id/cbCompleted"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:text="루틴 이름" />

            <TextView
                android:id="@+id/tvRoutineDetail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="12sp"
                android:textColor="@color/text_sub"
                app:layout_constraintStart_toStartOf="@id/tvRoutineName"
                app:layout_constraintTop_toBottomOf="@id/tvRoutineName"
                app:layout_constraintEnd_toEndOf="parent"
                android:text="상세 내용" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Memo Text -->
        <TextView
            android:id="@+id/tvRoutineMemo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp"
            android:padding="12dp"
            android:minHeight="60dp"
            android:background="@drawable/bg_rounded_gray"
            android:textSize="14sp"
            android:textColor="@color/text_main"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/innerBox"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="오늘의 메모"
            android:visibility="gone" />

        <!-- Consecutive Days Badge -->
        <TextView
            android:id="@+id/tvConsecutive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_rounded_gray"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:textColor="@color/text_main"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tvRoutineMemo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="4일 연속 성공" />

        <!-- Days of Week -->
        <LinearLayout
            android:id="@+id/layoutDays"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvConsecutive"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            
            <TextView android:id="@+id/dayMon" android:layout_width="24dp" android:layout_height="24dp" android:text="월" android:gravity="center" android:textSize="12sp" android:background="@drawable/bg_circle_day_inactive" android:textColor="@color/text_sub" android:layout_marginEnd="6dp"/>
            <TextView android:id="@+id/dayTue" android:layout_width="24dp" android:layout_height="24dp" android:text="화" android:gravity="center" android:textSize="12sp" android:background="@drawable/bg_circle_day_inactive" android:textColor="@color/text_sub" android:layout_marginEnd="6dp"/>
            <TextView android:id="@+id/dayWed" android:layout_width="24dp" android:layout_height="24dp" android:text="수" android:gravity="center" android:textSize="12sp" android:background="@drawable/bg_circle_day_inactive" android:textColor="@color/text_sub" android:layout_marginEnd="6dp"/>
            <TextView android:id="@+id/dayThu" android:layout_width="24dp" android:layout_height="24dp" android:text="목" android:gravity="center" android:textSize="12sp" android:background="@drawable/bg_circle_day_inactive" android:textColor="@color/text_sub" android:layout_marginEnd="6dp"/>
            <TextView android:id="@+id/dayFri" android:layout_width="24dp" android:layout_height="24dp" android:text="금" android:gravity="center" android:textSize="12sp" android:background="@drawable/bg_circle_day_inactive" android:textColor="@color/text_sub" android:layout_marginEnd="6dp"/>
            <TextView android:id="@+id/daySat" android:layout_width="24dp" android:layout_height="24dp" android:text="토" android:gravity="center" android:textSize="12sp" android:background="@drawable/bg_circle_day_inactive" android:textColor="@color/text_sub" android:layout_marginEnd="6dp"/>
            <TextView android:id="@+id/daySun" android:layout_width="24dp" android:layout_height="24dp" android:text="일" android:gravity="center" android:textSize="12sp" android:background="@drawable/bg_circle_day_inactive" android:textColor="@color/text_sub" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
